# ──────────────────────────────────────────────
#  Firebase configuration
# ──────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values from your
# Firebase project (Project Settings → General → Your apps → Web).
#
# Without these vars, Warp runs in localStorage-only mode.
# With them set, likes / profile are persisted to Firestore.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ──────────────────────────────────────────────
#  LINE Login (OAuth 2.0 / OIDC)
# ──────────────────────────────────────────────
# Register a "LINE Login" channel at https://developers.line.biz/console/
# and copy the Channel ID below.
#
# In the channel's "LINEログイン設定" panel, register the callback URL:
#   - Production: https://playmark0227-svg.github.io/swiply/login/line/callback/
#   - Local dev:  http://localhost:3000/login/line/callback/
#
# To receive the user's email, also enable
# "メールアドレス取得権限の申請" (additional review may be required).
#
# Channel Secret is NOT needed — the SPA uses the PKCE flow.

NEXT_PUBLIC_LINE_CHANNEL_ID=

# ──────────────────────────────────────────────
#  LIFF (LINE Front-end Framework) — for rich-menu auto-login
# ──────────────────────────────────────────────
# Powers /liff/, the page the LINE Official Account rich menu links to.
# When the user taps the rich menu, LINE opens this page inside its
# in-app browser; liff.init() resolves the user without any extra tap,
# the AuthProvider session is set, and we redirect to ?next= (default /).
#
# Setup:
#   1. https://developers.line.biz/console/ → open the existing
#      "SWIPLY" LINE Login channel (the same one NEXT_PUBLIC_LINE_CHANNEL_ID
#      points to).
#   2. "LIFF" tab → Add → fill in:
#        - LIFFアプリ名:   SWIPLY (or anything)
#        - サイズ:         Full
#        - エンドポイントURL:
#            https://playmark0227-svg.github.io/swiply/liff/    (production)
#            http://localhost:3000/liff/                         (local dev)
#        - Scope:          profile, openid   (email is optional)
#        - ボットリンク機能: On (Aggressive) recommended
#   3. Copy the resulting LIFF ID (looks like "2005114375-XaBcDeFg")
#      into NEXT_PUBLIC_LIFF_ID below.
#   4. In LINE Official Account Manager → SWIPLY → リッチメニュー,
#      replace the rich-menu button URL with:
#            https://liff.line.me/<NEXT_PUBLIC_LIFF_ID>
#      Optional ?next= parameter is supported, e.g.
#            https://liff.line.me/<id>?next=/career

NEXT_PUBLIC_LIFF_ID=
